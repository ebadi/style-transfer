{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "realisticVisionV51.safetensors"
    }
  },
  "2": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip":  ["1", 1],
      "lora_name":       "factory_lora.safetensors",
      "strength_model":  0.85,
      "strength_clip":   0.85
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_comment": "positive prompt",
    "inputs": {
      "text": "photorealistic industrial factory, warehouse interior, worn concrete floor texture, overhead birds-eye view, dramatic tilt angle, AMR automated mobile robot, metal shelving, yellow hazard stripe, yellow safety walkway markers, sharp details, high resolution, industrial photography, DSLR, physically based rendering, realistic lighting",
      "clip": ["2", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_comment": "negative prompt",
    "inputs": {
      "text": "animated, cartoon, 3d render, cgi, unrealistic, blurry, low quality, painterly, illustration, sketch, oversaturated, glowing white orb lighting, overexposed",
      "clip": ["2", 1]
    }
  },
  "5": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control_v11p_sd15_canny.safetensors"
    }
  },
  "6": {
    "class_type": "LoadImage",
    "_comment": "input Gazebo frame — filename updated per-frame by the worker",
    "inputs": {
      "image": "input_frame_000000.png"
    }
  },
  "7": {
    "class_type": "ImageScale",
    "_comment": "scale frame to processing resolution before ControlNet preprocessing",
    "inputs": {
      "image":           ["6", 0],
      "upscale_method":  "lanczos",
      "width":           768,
      "height":          448,
      "crop":            "disabled"
    }
  },
  "8": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image":           ["7", 0],
      "low_threshold":   100,
      "high_threshold":  200,
      "resolution":      768
    }
  },
  "9": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_vit_h.safetensors"
    }
  },
  "10": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sd15.safetensors"
    }
  },
  "11": {
    "class_type": "LoadImage",
    "_comment": "style reference — single fixed factory image uploaded once and reused for all frames",
    "inputs": {
      "image": "style_ref_000000.jpg"
    }
  },
  "12": {
    "class_type": "IPAdapterAdvanced",
    "_comment": "injects color and texture from the real factory image",
    "inputs": {
      "model":           ["2", 0],
      "ipadapter":       ["10", 0],
      "image":           ["11", 0],
      "clip_vision":     ["9", 0],
      "weight":          0.55,
      "weight_type":     "linear",
      "combine_embeds":  "concat",
      "start_at":        0.0,
      "end_at":          1.0,
      "embeds_scaling":  "V only"
    }
  },
  "13": {
    "class_type": "ControlNetApplyAdvanced",
    "_comment": "preserves the geometric structure of the Gazebo scene",
    "inputs": {
      "positive":        ["3", 0],
      "negative":        ["4", 0],
      "control_net":     ["5", 0],
      "image":           ["8", 0],
      "strength":        0.80,
      "start_percent":   0.0,
      "end_percent":     0.85
    }
  },
  "14": {
    "class_type": "VAEEncode",
    "_comment": "encode the (scaled) input frame to latent space for img2img",
    "inputs": {
      "pixels": ["7", 0],
      "vae":    ["1", 2]
    }
  },
  "15": {
    "class_type": "KSampler",
    "inputs": {
      "model":          ["12", 0],
      "positive":       ["13", 0],
      "negative":       ["13", 1],
      "latent_image":   ["14", 0],
      "seed":           42,
      "steps":          28,
      "cfg":            7.5,
      "sampler_name":   "euler",
      "scheduler":      "karras",
      "denoise":        0.40
    }
  },
  "16": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["15", 0],
      "vae":     ["1", 2]
    }
  },
  "17": {
    "class_type": "ImageScale",
    "_comment": "scale back to original video resolution — width/height updated per-frame by worker",
    "inputs": {
      "image":           ["16", 0],
      "upscale_method":  "lanczos",
      "width":           1280,
      "height":          720,
      "crop":            "disabled"
    }
  },
  "18": {
    "class_type": "SaveImage",
    "inputs": {
      "images":            ["17", 0],
      "filename_prefix":   "styled_frame_000000"
    }
  }
}
